# region Get-PSUProgramAnalysis.ps1

function Get-PSUProgramAnalysis {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [string]$Name
    )

    $matches = @(Get-PSURegistryProgram -Name $Name)

    if ($matches.Count -eq 0) {
        $result = New-PSUAnalyzeResult -Query $Name
        $result.Notes = 'Nenhum programa encontrado no Registry.'
        return $result
    }

    foreach ($match in $matches) {
        ConvertTo-PSUAnalyzeResult -Query $Name -RegistryMatch $match
    }
}

