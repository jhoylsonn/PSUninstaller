# region Invoke-PSUUninstall.ps1

function Split-PSUCommandLine {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [string]$CommandLine
    )

    $expanded = [Environment]::ExpandEnvironmentVariables($CommandLine.Trim())

    if ($expanded -match '^\s*"([^"]+)"\s*(.*)$') {
        return [PSCustomObject]@{
            FilePath = $Matches[1]
            Arguments = $Matches[2].Trim()
        }
    }

    if ($expanded -match '^\s*([A-Za-z]:\\Program Files(?: \(x86\))?\\.*?\.exe)\s*(.*)$') {
        return [PSCustomObject]@{
            FilePath = $Matches[1]
            Arguments = $Matches[2].Trim()
        }
    }

    if ($expanded -match '^\s*([^\s]+)\s*(.*)$') {
        return [PSCustomObject]@{
            FilePath = $Matches[1]
            Arguments = $Matches[2].Trim()
        }
    }

    return $null
}

function Add-PSUSilentArgument {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [string]$FilePath,

        [AllowNull()]
        [string]$Arguments
    )

    if ($Arguments -match '(^|\s)(/S|/silent|/quiet|/qn)(\s|$)') {
        return $Arguments
    }

    $leaf = Split-Path -Path $FilePath -Leaf

    switch -Regex ($leaf) {
        '^(helper|uninstall)\.exe$' { return ($Arguments + ' /S').Trim() }
        '^unins\d*\.exe$'          { return ($Arguments + ' /VERYSILENT /SUPPRESSMSGBOXES /NORESTART').Trim() }
        default                    { return $Arguments }
    }
}

function Invoke-PSUProcess {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [string]$FilePath,

        [AllowNull()]
        [string]$ArgumentList,

        [int]$TimeoutSeconds = 1800
    )

    Write-Host "Executando: $FilePath $ArgumentList"

    if ($FilePath -ne 'msiexec.exe' -and -not (Test-Path -LiteralPath $FilePath)) {
        Write-Warning "Arquivo de desinstalacao nao encontrado: $FilePath"
        return -1
    }

    try {
        $process = Start-Process -FilePath $FilePath -ArgumentList $ArgumentList -PassThru -WindowStyle Normal -ErrorAction Stop
    }
    catch {
        Write-Warning "Falha ao iniciar desinstalador: $($_.Exception.Message)"
        return -1
    }

    if (-not $process) {
        Write-Warning 'Falha ao iniciar desinstalador: processo nao retornado.'
        return -1
    }

    $elapsed = 0
    while (-not $process.HasExited) {
        Start-Sleep -Seconds 1
        $elapsed++

        if (($elapsed % 5) -eq 0) {
            Write-Progress -Activity 'PSUninstaller' -Status "Aguardando desinstalador finalizar... $elapsed s" -PercentComplete -1
        }

        if ($TimeoutSeconds -gt 0 -and $elapsed -ge $TimeoutSeconds) {
            try { $process.Kill() } catch {}
            Write-Progress -Activity 'PSUninstaller' -Completed
            throw "Timeout: o desinstalador nao finalizou em $TimeoutSeconds segundos."
        }
    }

    Write-Progress -Activity 'PSUninstaller' -Completed
    Write-Host "Processo finalizado. ExitCode: $($process.ExitCode)"
    return $process.ExitCode
}


function Get-PSUResidualCandidatePath {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [object]$Analysis
    )

    $tokens = @()

    foreach ($value in @($Analysis.Name, $Analysis.Query, $Analysis.Publisher)) {
        if ([string]::IsNullOrWhiteSpace($value)) { continue }

        $tokens += $value
        $tokens += ($value -replace '\s*[-_]?64\s*bit\s*', '')
        $tokens += ($value -replace '[^A-Za-z0-9]', '')
    }

    if ($Analysis.InstallLocation) {
        $tokens += (Split-Path -Path $Analysis.InstallLocation -Leaf)
    }

    $uninstallFilePath = $null
    if (-not [string]::IsNullOrWhiteSpace($Analysis.UninstallString)) {
        $expandedUninstallString = [Environment]::ExpandEnvironmentVariables($Analysis.UninstallString.Trim())
        if ($expandedUninstallString -match '^\s*"([^"]+)"') {
            $uninstallFilePath = $Matches[1]
        }
        elseif ($expandedUninstallString -match '^\s*([A-Za-z]:\\Program Files(?: \(x86\))?\\.*?\.exe)') {
            $uninstallFilePath = $Matches[1]
        }
        elseif ($expandedUninstallString -match '^\s*([^\s]+)') {
            $uninstallFilePath = $Matches[1]
        }
    }

    $uninstallDirectory = $null
    $vendorDirectory = $null
    if (-not [string]::IsNullOrWhiteSpace($uninstallFilePath)) {
        $uninstallDirectory = Split-Path -Path $uninstallFilePath -Parent
        if (-not [string]::IsNullOrWhiteSpace($uninstallDirectory)) {
            $tokens += (Split-Path -Path $uninstallDirectory -Leaf)
            $vendorDirectory = Split-Path -Path $uninstallDirectory -Parent
            if (-not [string]::IsNullOrWhiteSpace($vendorDirectory)) {
                $tokens += (Split-Path -Path $vendorDirectory -Leaf)
            }
        }
    }

    $tokens = @($tokens | Where-Object { -not [string]::IsNullOrWhiteSpace($_) } | ForEach-Object { $_.Trim() } | Where-Object { $_.Length -ge 3 } | Sort-Object -Unique)

    $basePaths = @(
        $Analysis.InstallLocation,
        $uninstallDirectory,
        $vendorDirectory,
        $env:ProgramFiles,
        ${env:ProgramFiles(x86)},
        $env:ProgramData,
        $env:APPDATA,
        $env:LOCALAPPDATA,
        (Join-Path $env:ProgramData 'Microsoft\Windows\Start Menu\Programs'),
        (Join-Path $env:APPDATA 'Microsoft\Windows\Start Menu\Programs'),
        ([Environment]::GetFolderPath('Desktop'))
    ) | Where-Object { -not [string]::IsNullOrWhiteSpace($_) } | Sort-Object -Unique

    $candidates = New-Object System.Collections.Generic.List[string]

    foreach ($explicitPath in @($Analysis.InstallLocation, $uninstallDirectory)) {
        if (-not [string]::IsNullOrWhiteSpace($explicitPath) -and (Test-Path -LiteralPath $explicitPath)) {
            $candidates.Add($explicitPath)
        }
    }

    foreach ($path in $basePaths) {
        if ([string]::IsNullOrWhiteSpace($path)) { continue }

        if (Test-Path -LiteralPath $path) {
            if ($path -eq $Analysis.InstallLocation) {
                $candidates.Add($path)
                continue
            }

            foreach ($token in $tokens) {
                $direct = Join-Path $path $token
                if (Test-Path -LiteralPath $direct) {
                    $candidates.Add($direct)
                }
            }

            try {
                Get-ChildItem -LiteralPath $path -Force -ErrorAction SilentlyContinue |
                    Where-Object {
                        $itemName = $_.Name
                        foreach ($token in $tokens) {
                            if ($itemName -like "*$token*") { return $true }
                        }
                        return $false
                    } |
                    ForEach-Object { $candidates.Add($_.FullName) }
            }
            catch {}
        }
    }

    $candidates | Sort-Object -Unique
}

function Get-PSUResidualRegistryPath {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [object]$Analysis
    )

    $tokens = @($Analysis.Name, $Analysis.Query, $Analysis.Publisher) |
        Where-Object { -not [string]::IsNullOrWhiteSpace($_) } |
        ForEach-Object { $_.Trim() } |
        Where-Object { $_.Length -ge 3 } |
        Sort-Object -Unique

    $roots = @(
        'HKCU:\Software',
        'HKLM:\Software',
        'HKLM:\Software\WOW6432Node',
        'HKCU:\Software\Microsoft\Windows\CurrentVersion\Uninstall',
        'HKLM:\Software\Microsoft\Windows\CurrentVersion\Uninstall',
        'HKLM:\Software\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall'
    )

    $candidates = New-Object System.Collections.Generic.List[string]

    foreach ($root in $roots) {
        if (-not (Test-Path -LiteralPath $root)) { continue }

        try {
            Get-ChildItem -LiteralPath $root -ErrorAction SilentlyContinue |
                Where-Object {
                    $keyName = $_.PSChildName
                    $displayName = $null
                    try { $displayName = (Get-ItemProperty -LiteralPath $_.PSPath -ErrorAction SilentlyContinue).DisplayName } catch {}

                    foreach ($token in $tokens) {
                        if ($keyName -like "*$token*" -or $displayName -like "*$token*") { return $true }
                    }
                    return $false
                } |
                ForEach-Object { $candidates.Add($_.PSPath) }
        }
        catch {}
    }

    $candidates | Sort-Object -Unique
}

function Invoke-PSUResidualCleanup {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [object]$Analysis,

        [switch]$Force
    )

    $paths = @(Get-PSUResidualCandidatePath -Analysis $Analysis)
    $registryPaths = @(Get-PSUResidualRegistryPath -Analysis $Analysis)

    Write-Host "Limpeza residual: arquivos/pastas encontrados: $($paths.Count)"
    Write-Host "Limpeza residual: chaves de registro encontradas: $($registryPaths.Count)"

    if (($paths.Count + $registryPaths.Count) -eq 0) {
        Write-Host 'Limpeza residual: nenhum residuo detectado.'
        return
    }

    if (-not $Force) {
        Write-Host 'Limpeza residual nao removida automaticamente sem -Force.'
        return
    }

    foreach ($path in $paths) {
        try {
            Remove-Item -LiteralPath $path -Recurse -Force -ErrorAction Stop
            Write-Host "Removido: $path"
        }
        catch {
            Write-Warning "Falha ao remover residuo: $path - $($_.Exception.Message)"
        }
    }

    foreach ($registryPath in $registryPaths) {
        try {
            Remove-Item -LiteralPath $registryPath -Recurse -Force -ErrorAction Stop
            Write-Host "Registro removido: $registryPath"
        }
        catch {
            Write-Warning "Falha ao remover registro residual: $registryPath - $($_.Exception.Message)"
        }
    }
}

function Invoke-PSUUninstall {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [object]$Analysis,

        [switch]$Silent,
        [switch]$Clean,
        [switch]$Force
    )

    if (-not $Analysis.Found) {
        Write-Warning "Programa nao encontrado: $($Analysis.Query)"
        return
    }

    Write-Host ''
    Write-Host '============================================================'
    Write-Host "PSUninstaller: $($Analysis.Name)"
    Write-Host '============================================================'
    Write-Host "Tipo    : $($Analysis.Type)"
    Write-Host "Metodo  : $($Analysis.UninstallMethod)"
    Write-Host "Escopo  : $($Analysis.Scope)"
    Write-Host "Silent  : $([bool]$Silent)"
    Write-Host "Force   : $([bool]$Force)"
    Write-Host "Clean   : $([bool]$Clean)"
    Write-Host ''

    switch ($Analysis.UninstallMethod) {
        'MsiExec' {
            $productCode = $null

            if ($Analysis.UninstallString -match '\{[0-9A-Fa-f-]{36}\}') {
                $productCode = $Matches[0]
            }

            if (-not $productCode -and $Analysis.Name) {
                Write-Warning "ProductCode MSI nao encontrado para: $($Analysis.Name)"
                return
            }

            $args = if ($Silent -or $Force) { "/x $productCode /qn /norestart" } else { "/x $productCode" }
            Invoke-PSUProcess -FilePath 'msiexec.exe' -ArgumentList $args | Out-Null
        }

        'QuietUninstallString' {
            $cmd = Split-PSUCommandLine -CommandLine $Analysis.QuietUninstallString
            if (-not $cmd) { throw 'QuietUninstallString invalida.' }

            Invoke-PSUProcess -FilePath $cmd.FilePath -ArgumentList $cmd.Arguments | Out-Null
        }

        'RegistryUninstallString' {
            $cmd = Split-PSUCommandLine -CommandLine $Analysis.UninstallString
            if (-not $cmd) { throw 'UninstallString invalida.' }

            $args = $cmd.Arguments
            if ($Silent -or $Force) {
                $args = Add-PSUSilentArgument -FilePath $cmd.FilePath -Arguments $args
            }

            Invoke-PSUProcess -FilePath $cmd.FilePath -ArgumentList $args | Out-Null
        }

        default {
            Write-Warning "Metodo de desinstalacao nao suportado: $($Analysis.UninstallMethod)"
        }
    }

    if ($Clean) {
        Invoke-PSUResidualCleanup -Analysis $Analysis -Force:$Force
    }
}

# endregion Invoke-PSUUninstall.ps1

# region New-PSUAnalyzeResult.ps1

function New-PSUAnalyzeResult {
    [CmdletBinding()]
    param(
        [string]$Query,
        [bool]$Found = $false
    )

    [PSCustomObject]@{
        Name                 = $null
        Query                = $Query
        Version              = $null
        Publisher            = $null
        InstallLocation      = $null

        Type                 = 'Unknown'
        Source               = 'Unknown'
        Scope                = 'Unknown'

        UninstallMethod      = 'Unknown'
        UninstallString      = $null
        QuietUninstallString = $null

        SilentSupported      = $false
        CleanSupported       = $false
        RequiresElevation    = $true

        Confidence           = 0.0
        RiskLevel            = 'Unknown'

        Found                = $Found
        Status               = if ($Found) { 'Analyzed' } else { 'NotFound' }
        Notes                = $null
    }
}

