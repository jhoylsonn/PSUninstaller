# region ConvertTo-PSUAnalyzeResult.ps1

function ConvertTo-PSUAnalyzeResult {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [string]$Query,

        [Parameter(Mandatory)]
        [object]$RegistryMatch
    )

    $program = $RegistryMatch.Raw
    $result  = New-PSUAnalyzeResult -Query $Query -Found $true

    $displayName          = Get-PSUObjectProperty -InputObject $program -Name 'DisplayName'
    $displayVersion       = Get-PSUObjectProperty -InputObject $program -Name 'DisplayVersion'
    $publisher            = Get-PSUObjectProperty -InputObject $program -Name 'Publisher'
    $installLocation      = Get-PSUObjectProperty -InputObject $program -Name 'InstallLocation'
    $uninstallString      = Get-PSUObjectProperty -InputObject $program -Name 'UninstallString'
    $quietUninstallString = Get-PSUObjectProperty -InputObject $program -Name 'QuietUninstallString'
    $windowsInstaller     = Get-PSUObjectProperty -InputObject $program -Name 'WindowsInstaller' -Default 0

    $result.Name                 = $displayName
    $result.Version              = $displayVersion
    $result.Publisher            = $publisher
    $result.InstallLocation      = $installLocation
    $result.Source               = 'Registry'
    $result.Scope                = $RegistryMatch.Scope
    $result.UninstallString      = $uninstallString
    $result.QuietUninstallString = $quietUninstallString
    $result.SilentSupported      = -not [string]::IsNullOrWhiteSpace($quietUninstallString)
    $result.CleanSupported       = -not [string]::IsNullOrWhiteSpace($installLocation)
    $result.RequiresElevation    = $RegistryMatch.Scope -eq 'Machine'


    $uninstallCommandPath = $null
    if (-not [string]::IsNullOrWhiteSpace($uninstallString)) {
        $expandedUninstallString = [Environment]::ExpandEnvironmentVariables($uninstallString.Trim())
        if ($expandedUninstallString -match '^\s*"([^"]+)"') {
            $uninstallCommandPath = $Matches[1]
        }
        elseif ($expandedUninstallString -match '^\s*([A-Za-z]:\\Program Files(?: \(x86\))?\\.*?\.exe)') {
            $uninstallCommandPath = $Matches[1]
        }
        elseif ($expandedUninstallString -match '^\s*([^\s]+)') {
            $uninstallCommandPath = $Matches[1]
        }
    }

    $isRegistryOrphan = $false
    if (-not [string]::IsNullOrWhiteSpace($uninstallCommandPath) -and $uninstallCommandPath -ne 'msiexec.exe') {
        $isRegistryOrphan = -not (Test-Path -LiteralPath $uninstallCommandPath)
    }

    if ($isRegistryOrphan) {
        $result.Status         = 'ResidualDetected'
        $result.Found          = $true
        $result.Confidence     = 0.60
        $result.RiskLevel      = 'Medium'
        $result.CleanSupported = $true
        $result.Notes          = 'Entrada residual detectada no Registry; arquivo de desinstalacao nao foi encontrado.'
    }

    $productCode = Get-PSUMsiProductCode -Program $program
    $isMsi = ($windowsInstaller -eq 1) -or (-not [string]::IsNullOrWhiteSpace($productCode))

    if ($isRegistryOrphan -and -not $isMsi) {
        $result.Type            = 'EXE'
        $result.UninstallMethod = if (-not [string]::IsNullOrWhiteSpace($uninstallString)) { 'RegistryUninstallString' } else { 'Unknown' }
        return $result
    }

    if ($isMsi) {
        $result.Type            = 'MSI'
        $result.UninstallMethod = 'MsiExec'
        $result.Confidence      = 0.95
        $result.RiskLevel       = 'Low'
        $result.Notes           = 'Programa MSI detectado com ProductCode valido.'
        return $result
    }

    if (-not [string]::IsNullOrWhiteSpace($quietUninstallString)) {
        $result.Type            = 'EXE'
        $result.UninstallMethod = 'QuietUninstallString'
        $result.Confidence      = 0.90
        $result.RiskLevel       = 'Low'
        $result.Notes           = 'QuietUninstallString disponivel.'
        return $result
    }

    if (-not [string]::IsNullOrWhiteSpace($uninstallString)) {
        $result.Type            = 'EXE'
        $result.UninstallMethod = 'RegistryUninstallString'
        $result.Confidence      = 0.85
        $result.RiskLevel       = 'Medium'
        $result.Notes           = 'UninstallString encontrada, mas QuietUninstallString nao esta disponivel.'
        return $result
    }

    $result.Type            = 'Unknown'
    $result.UninstallMethod = 'Unknown'
    $result.Confidence      = 0.50
    $result.RiskLevel       = 'High'
    $result.Status          = 'Unsupported'
    $result.Notes           = 'Programa encontrado, mas nenhum metodo confiavel de desinstalacao foi detectado.'

    return $result
}

# endregion ConvertTo-PSUAnalyzeResult.ps1

# region Get-PSUInstalledProgram.ps1

function Get-PSUInstalledProgram {
    [CmdletBinding()]
    param(
        [switch]$IncludeAppx,
        [switch]$IncludeUpdates,
        [switch]$IncludeSystemComponent
    )

    $registryPrograms = foreach ($match in @(Get-PSURegistryProgram -IncludeUpdates:$IncludeUpdates -IncludeSystemComponent:$IncludeSystemComponent)) {
        ConvertTo-PSUAnalyzeResult -Query '*' -RegistryMatch $match
    }

    foreach ($program in $registryPrograms | Sort-Object Name, Version -Unique) {
        [PSCustomObject]@{
            Name            = $program.Name
            Version         = $program.Version
            Publisher       = $program.Publisher
            Type            = $program.Type
            Source          = $program.Source
            Scope           = $program.Scope
            SilentSupported = $program.SilentSupported
            UninstallMethod = $program.UninstallMethod
        }
    }

    if ($IncludeAppx) {
        try {
            Get-AppxPackage -ErrorAction Stop |
                Where-Object { -not [string]::IsNullOrWhiteSpace($_.Name) } |
                Sort-Object Name |
                ForEach-Object {
                    [PSCustomObject]@{
                        Name              = $_.Name
                        Version           = if ($_.Version) { $_.Version.ToString() } else { $null }
                        Publisher         = $_.Publisher
                        InstallLocation   = $_.InstallLocation
                        Type              = 'APPX'
                        Source            = 'Appx'
                        Scope             = 'User'
                        SilentSupported   = $true
                        UninstallMethod   = 'Remove-AppxPackage'
                        Confidence        = 0.95
                        RiskLevel         = 'Low'
                        CleanSupported    = $false
                        RequiresElevation = $false
                        Found             = $true
                        Status            = 'Analyzed'
                        Notes             = 'Aplicativo Microsoft Store/AppX.'
                    }
                }
        }
        catch {
            Write-Warning "Nao foi possivel listar Appx: $($_.Exception.Message)"
        }
    }
}

# endregion Get-PSUInstalledProgram.ps1

# region Get-PSUMsiProductCode.ps1

function Get-PSUMsiProductCode {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [object]$Program
    )

    $childName = Get-PSUObjectProperty -InputObject $Program -Name 'PSChildName'
    $uninstall = Get-PSUObjectProperty -InputObject $Program -Name 'UninstallString'

    if ($childName -match '^\{[0-9A-Fa-f-]{36}\}$') {
        return $childName
    }

    if ($uninstall -match '\{[0-9A-Fa-f-]{36}\}') {
        return $Matches[0]
    }

    return $null
}

# endregion Get-PSUMsiProductCode.ps1

# region Get-PSUObjectProperty.ps1

function Get-PSUObjectProperty {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [object]$InputObject,

        [Parameter(Mandatory)]
        [string]$Name,

        [object]$Default = $null
    )

    if ($null -eq $InputObject) {
        return $Default
    }

    $property = $InputObject.PSObject.Properties[$Name]

    if ($null -eq $property) {
        return $Default
    }

    return $property.Value
}

