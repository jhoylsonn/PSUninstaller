# region Get-PSURegistryProgram.ps1

function Get-PSURegistryProgram {
    [CmdletBinding()]
    param(
        [AllowNull()]
        [AllowEmptyString()]
        [string]$Name,

        [switch]$IncludeUpdates,
        [switch]$IncludeSystemComponent
    )

    $registryPaths = @(
        @{ Path = 'HKLM:\Software\Microsoft\Windows\CurrentVersion\Uninstall\*'; Scope = 'Machine' },
        @{ Path = 'HKLM:\Software\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall\*'; Scope = 'Machine' },
        @{ Path = 'HKCU:\Software\Microsoft\Windows\CurrentVersion\Uninstall\*'; Scope = 'User' }
    )

    foreach ($item in $registryPaths) {
        $items = @(Get-ItemProperty -Path $item.Path -ErrorAction SilentlyContinue)

        foreach ($program in $items) {
            $displayName = Get-PSUObjectProperty -InputObject $program -Name 'DisplayName'

            if ([string]::IsNullOrWhiteSpace($displayName)) {
                continue
            }

            $systemComponent = Get-PSUObjectProperty -InputObject $program -Name 'SystemComponent' -Default 0
            if (-not $IncludeSystemComponent -and $systemComponent -eq 1) {
                continue
            }

            $releaseType = Get-PSUObjectProperty -InputObject $program -Name 'ReleaseType'
            $parentKeyName = Get-PSUObjectProperty -InputObject $program -Name 'ParentKeyName'
            $hotFixId = Get-PSUObjectProperty -InputObject $program -Name 'HotFixID'
            $isUpdate = (-not [string]::IsNullOrWhiteSpace($releaseType)) -or
                        (-not [string]::IsNullOrWhiteSpace($parentKeyName)) -or
                        (-not [string]::IsNullOrWhiteSpace($hotFixId))

            if (-not $IncludeUpdates -and $isUpdate) {
                continue
            }

            if ([string]::IsNullOrWhiteSpace($Name) -or $displayName -like "*$Name*") {
                [PSCustomObject]@{
                    Raw   = $program
                    Scope = $item.Scope
                }
            }
        }
    }
}

