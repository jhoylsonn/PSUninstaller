# region Write-PSUObjectBlock.ps1

function Write-PSUObjectBlock {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory, ValueFromPipeline)]
        [object[]]$InputObject,

        [string[]]$Property,

        [switch]$ShowCount
    )

    begin {
        $items = New-Object System.Collections.Generic.List[object]
    }

    process {
        foreach ($item in $InputObject) {
            if ($null -ne $item) { [void]$items.Add($item) }
        }
    }

    end {
        if ($ShowCount) {
            Write-Host ''
            Write-Host "Programas encontrados: $($items.Count)"
        }

        $index = 0
        foreach ($item in $items) {
            if ($index -gt 0 -or $ShowCount) {
                Write-Host ''
                Write-Host ('=' * 60)
                Write-Host ''
            }

            if ($Property -and $Property.Count -gt 0) {
                $item | Select-Object -Property $Property | Format-List | Out-Host
            }
            else {
                $item | Format-List | Out-Host
            }

            $index++
        }
    }
}

# endregion Write-PSUObjectBlock.ps1

# region Invoke-PSUninstaller.ps1

function Invoke-PSUninstaller {
    [CmdletBinding(
        DefaultParameterSetName = 'Default',
        SupportsShouldProcess = $true,
        ConfirmImpact = 'High'
    )]
    param(
        [Parameter(
            Position = 0,
            ValueFromPipeline,
            ValueFromPipelineByPropertyName,
            ParameterSetName = 'Default'
        )]
        [Parameter(
            Position = 0,
            ValueFromPipeline,
            ValueFromPipelineByPropertyName,
            ParameterSetName = 'UninstallByName'
        )]
        [Parameter(
            Position = 0,
            ValueFromPipeline,
            ValueFromPipelineByPropertyName,
            ParameterSetName = 'Analyze'
        )]
        [Parameter(
            Position = 0,
            ParameterSetName = 'List'
        )]
        [Alias('DisplayName')]
        [string[]]$Name,

        [Parameter(ParameterSetName = 'UninstallByName', Mandatory)]
        [switch]$Uninstall,

        [Parameter(ParameterSetName = 'Analyze', Mandatory)]
        [switch]$Analyze,

        [Parameter(ParameterSetName = 'List')]
        [switch]$ListPrograms,

        [Parameter(ParameterSetName = 'List')]
        [switch]$IncludeAppx,

        [Parameter(ParameterSetName = 'List')]
        [switch]$IncludeUpdates,

        [Parameter(ParameterSetName = 'List')]
        [switch]$IncludeSystemComponent,

        [Parameter(ParameterSetName = 'Default')]
        [Parameter(ParameterSetName = 'Analyze')]
        [Parameter(ParameterSetName = 'List')]
        [switch]$AsObject,

        [Parameter(ParameterSetName = 'List')]
        [switch]$AsObjectList,

        [Parameter(ParameterSetName = 'Default')]
        [Parameter(ParameterSetName = 'Analyze')]
        [Parameter(ParameterSetName = 'List')]
        [switch]$Pretty,

        [Parameter(ParameterSetName = 'Default')]
        [Parameter(ParameterSetName = 'UninstallByName')]
        [switch]$Silent,

        [Parameter(ParameterSetName = 'Default')]
        [Parameter(ParameterSetName = 'UninstallByName')]
        [switch]$Clean,

        [Parameter(ParameterSetName = 'Default')]
        [Parameter(ParameterSetName = 'UninstallByName')]
        [switch]$Force,

        [Parameter(ParameterSetName = 'Help')]
        [switch]$Help,

        [Parameter(ParameterSetName = 'Menu')]
        [switch]$Menu
    )

    process {
        if ($Help) {
            Show-PSUHelp
            return
        }

        if ($Menu) {
            Show-PSUMenu
            return
        }

        if ($ListPrograms -or $IncludeAppx -or $IncludeUpdates -or $IncludeSystemComponent) {
            $programs = @(Get-PSUInstalledProgram -IncludeAppx:$IncludeAppx -IncludeUpdates:$IncludeUpdates -IncludeSystemComponent:$IncludeSystemComponent)

            [array]$filters = @($Name | Where-Object { -not [string]::IsNullOrWhiteSpace($_) })

            if ($filters.Count -gt 0) {
                $programs = @(
                    foreach ($filter in $filters) {
                        $escapedFilter = [regex]::Escape($filter)
                        $programs | Where-Object { $_.Name -match $escapedFilter }
                    }
                ) | Sort-Object Name -Unique
            }

            if ($AsObject -or $AsObjectList) {
                $programs
                return
            }

            Write-Host ''
            Write-Host "Programas encontrados: $($programs.Count)"
            Write-Host ''

            if ($programs.Count -gt 0) {
                Write-Host '============================================================'
                Write-Host ''
                Write-Host '[ANALISE AVANCADA]'
                Write-Host ''
                Write-Host '============================================================'
                Write-Host ''

                foreach ($program in $programs) {
                    if ($program.Source -eq 'Appx') {
                        $program | Format-List Name,Version,Publisher,Type,Source,Scope,SilentSupported,UninstallMethod,Confidence,RiskLevel,CleanSupported,RequiresElevation,Found,Status,Notes
                        Write-Host ''
                        Write-Host '============================================================'
                        Write-Host ''
                        continue
                    }

                    $analysisResult = @(Get-PSUProgramAnalysis -Name $program.Name)
                    foreach ($result in $analysisResult) {
                        $result | Format-List Name,Version,Publisher,Type,Source,Scope,SilentSupported,UninstallMethod,Confidence,RiskLevel,CleanSupported,RequiresElevation,Found,Status,Notes
                        Write-Host ''
                        Write-Host '============================================================'
                        Write-Host ''
                    }
                }
            }

            return
        }

        if ($AsObject -and $PSCmdlet.ParameterSetName -eq 'Default') {
            [array]$objectTargets = @($Name | Where-Object { -not [string]::IsNullOrWhiteSpace($_) })

            foreach ($item in $objectTargets) {
                $analysisResult = @(Get-PSUProgramAnalysis -Name $item)

                foreach ($result in $analysisResult) {
                    if (-not $Pretty) {
                        $result
                        continue
                    }

                    Write-Host ''
                    Write-Host '============================================================'
                    Write-Host ''
                    $result | Format-List
                }
            }
            return
        }

        if ($PSCmdlet.ParameterSetName -eq 'Analyze') {
            [array]$analyzeTargets = @($Name | Where-Object { -not [string]::IsNullOrWhiteSpace($_) })

            if (-not $analyzeTargets -or $analyzeTargets.Count -eq 0) {
                Show-PSUStartInfo
                return
            }

            foreach ($item in $analyzeTargets) {
                if ([string]::IsNullOrWhiteSpace($item)) { continue }

                $analysisResult = @(Get-PSUProgramAnalysis -Name $item)

                foreach ($result in $analysisResult) {
                    if ($AsObject -and -not $Pretty) {
                        $result
                        continue
                    }

                    Write-Host ''
                    Write-Host '============================================================'
                    Write-Host ''
                    $result | Format-List
                }
            }
            return
        }

        [array]$targets = @($Name | Where-Object { -not [string]::IsNullOrWhiteSpace($_) })

        if (-not $targets -or $targets.Count -eq 0) {
            Show-PSUStartInfo
            return
        }

        foreach ($item in $targets) {
            if ([string]::IsNullOrWhiteSpace($item)) {
                continue
            }

            $analysisResult = @(Get-PSUProgramAnalysis -Name $item)

            foreach ($target in $analysisResult) {
                if (-not $target.Found) {
                    $target
                    continue
                }

                if ($Force -and -not $WhatIfPreference) {
                    Invoke-PSUUninstall -Analysis $target -Silent:$Silent -Clean:$Clean -Force:$Force
                    continue
                }

                if ($PSCmdlet.ShouldProcess($target.Name, 'Desinstalar programa')) {
                    Invoke-PSUUninstall -Analysis $target -Silent:$Silent -Clean:$Clean -Force:$Force
                }
            }
        }
    }
}

# endregion Invoke-PSUninstaller.ps1


Set-Alias -Name psu -Value Invoke-PSUninstaller -Force
Export-ModuleMember -Function Invoke-PSUninstaller -Alias psu
