    Write-Host '  psu -IncludeAppx "Xbox","Calculator"'
    Write-Host '  psu -IncludeUpdates'
    Write-Host '  psu -IncludeSystemComponent'
    Write-Host '  psu -ListPrograms -IncludeAppx -IncludeUpdates -IncludeSystemComponent'
    Write-Host '  psu -ListPrograms -AsObjectList | Format-Table Name,Version,Publisher,Type,Scope -AutoSize'
    Write-Host ''
    Write-Host 'Saida estruturada:'
    Write-Host ''
    Write-Host '  psu -Analyze Firefox -AsObject'
    Write-Host '  psu -AsObject "firefox","chrome" | Format-Table'
    Write-Host '  psu -ListPrograms -AsObject | Format-Table'
    Write-Host '  psu -Analyze Firefox -AsObject | ConvertTo-Json'
    Write-Host '  psu -Analyze Firefox -AsObject | Format-List *'
    Write-Host '  psu -ListPrograms -AsObjectList | Where-Object Name -match "Chrome"'
    Write-Host ''
    Write-Host 'Use psu -Menu para abrir o menu interativo.'
    Write-Host ''
}

# endregion Show-PSUHelp.ps1

# region Show-PSUMenu.ps1

function Show-PSUMenu {
    [CmdletBinding()]
    param()

    do {
        Clear-Host
        Write-Host '===================================================='
        Write-Host '        PSUninstaller'
        Write-Host '        Plataforma de Orquestracao de Software'
        Write-Host '===================================================='
        Write-Host ''
        Write-Host '1. Listar todos os programas instalados'
        Write-Host '2. Analisar programa instalado'
        Write-Host '3. Desinstalar programa'
        Write-Host '4. Desinstalar em modo silencioso'
        Write-Host '5. Desinstalar em modo silencioso + limpeza'
        Write-Host '6. Modo agressivo: Force + Clean'
        Write-Host '7. Analisar multiplos programas'
        Write-Host '8. Simular desinstalacao com WhatIf'
        Write-Host '9. Exemplos de saida estruturada'
        Write-Host '10. Ajuda rapida'
        Write-Host '0. Sair'
        Write-Host ''

        $choice = Read-Host 'Selecione uma opcao'

        switch ($choice) {
            '1' {
                Invoke-PSUninstaller -ListPrograms
                Pause
            }
            '2' {
                $name = Read-Host 'Nome do programa para analisar'
                if ($name) { Invoke-PSUninstaller -Analyze $name }
                Pause
            }
            '3' {
                $name = Read-Host 'Nome do programa para desinstalar'
                if ($name) { Invoke-PSUninstaller -Uninstall $name }
                Pause
            }
            '4' {
                $name = Read-Host 'Nome do programa para desinstalar silenciosamente'
                if ($name) { Invoke-PSUninstaller -Uninstall $name -Silent }
                Pause
            }
            '5' {
                $name = Read-Host 'Nome do programa para desinstalar silenciosamente com limpeza'
                if ($name) { Invoke-PSUninstaller -Uninstall $name -Silent -Clean }
                Pause
            }
            '6' {
                $name = Read-Host 'Nome do programa para modo agressivo'
                if ($name) { Invoke-PSUninstaller -Uninstall $name -Force -Clean }
                Pause
            }
            '7' {
                $raw = Read-Host 'Nomes separados por virgula. Exemplo: Firefox,Chrome'
                if ($raw) {
                    $names = $raw -split ',' | ForEach-Object { $_.Trim() } | Where-Object { $_ }
                    Invoke-PSUninstaller -Analyze $names
                }
                Pause
            }
            '8' {
                $name = Read-Host 'Nome do programa para simular desinstalacao'
                if ($name) { Invoke-PSUninstaller -Uninstall $name -Silent -Clean -WhatIf }
                Pause
            }
            '9' {
                Write-Host ''
                Write-Host 'Exemplos:'
                Write-Host '  psu -ListPrograms'
                Write-Host '  psu -Analyze Firefox'
                Write-Host '  psu -Analyze Firefox -AsObject | ConvertTo-Json'
                Write-Host '  psu -Uninstall Firefox -WhatIf'
                Write-Host '  psu -Uninstall Firefox -Silent -Clean'
                Write-Host '  psu -Uninstall Chrome,Firefox -Silent'
                Write-Host '  "Chrome","Firefox" | psu -Uninstall -Clean'
                Write-Host ''
                Pause
            }
            '10' {
                Show-PSUHelp
                Pause
            }
            '0' {
                return
            }
            default {
                Write-Host 'Opcao invalida.'
                Pause
            }
        }
    } while ($true)
}

# endregion Show-PSUMenu.ps1

